{
  "name": "@yazhivotnoe/argocd-mcp",
  "version": "0.0.1",
  "description": "Minimal ArgoCD MCP Server (Fastify)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "argocd-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:stateless": "tsx watch src/index.ts --stateless",
    "build": "tsup",
    "start": "node dist/index.js",
    "prepublishOnly": "yarn build",
    "version": "npm version patch",
    "publish": "npm publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.33",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "license": "Apache-2.0"
}
